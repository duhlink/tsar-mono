{
	"extends": "./tsconfig.base.json",
	"compilerOptions": {
		"noEmit": true,
		"paths": {
			"*": ["./*"],
			"@tsar/ai": ["./packages/ai/src/index.ts"],
			"@tsar/ai/oauth": ["./packages/ai/src/oauth.ts"],
			"@tsar/ai/*": ["./packages/ai/src/*"],
			"@tsar/ai/dist/*": ["./packages/ai/src/*"],
			"@tsar/agent-core": ["./packages/agent/src/index.ts"],
			"@tsar/agent-core/*": ["./packages/agent/src/*"],
			"@tsar/coding-agent": ["./packages/coding-agent/src/index.ts"],
			"@tsar/coding-agent/hooks": ["./packages/coding-agent/src/core/hooks/index.ts"],
			"@tsar/coding-agent/*": ["./packages/coding-agent/src/*"],
			"@sinclair/typebox": ["./node_modules/@sinclair/typebox"],
			"@tsar/mom": ["./packages/mom/src/index.ts"],
			"@tsar/mom/*": ["./packages/mom/src/*"],
			"@tsar/pods": ["./packages/pods/src/index.ts"],
			"@tsar/pods/*": ["./packages/pods/src/*"],
			"@tsar/tui": ["./packages/tui/src/index.ts"],
			"@tsar/tui/*": ["./packages/tui/src/*"],
			"@tsar/web-ui": ["./packages/web-ui/src/index.ts"],
			"@tsar/web-ui/*": ["./packages/web-ui/src/*"],
			"@tsar/agent-old": ["./packages/agent-old/src/index.ts"],
			"@tsar/agent-old/*": ["./packages/agent-old/src/*"]
		}
	},
	"include": ["packages/*/src/**/*", "packages/*/test/**/*", "packages/coding-agent/examples/**/*"],
	"exclude": ["packages/web-ui/**/*", "**/dist/**"]
}
